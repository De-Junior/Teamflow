generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  DEVELOPER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  USER_INVITED
  PROJECT_CREATED
  MENTIONED_IN_COMMENT
  SLA_WARNING
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum SubscriptionPlan {
  FREE
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  ARCHIVED
  RESTORED
  INVITED
  ROLE_CHANGED
  LOGIN
  LOGOUT
}

// ─── Tenant (Organisation) ────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  industry  String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?
  // Relations
  memberships   Membership[]
  projects      Project[]
  invitations   Invitation[]
  auditLogs     AuditLog[]
  notifications Notification[]
  subscription  Subscription?
  files         File[]

  @@index([slug])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth users
  phone         String?
  timezone      String?
  language      String?   @default("en")
  bio           String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts        Account[]
  sessions        Session[]
  memberships     Membership[]
  assignedTasks   Task[]          @relation("TaskAssignee")
  createdTasks    Task[]          @relation("TaskCreator")
  comments        Comment[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  invitationsSent Invitation[]    @relation("InvitedBy")
  files           File[]
  timeEntries     TimeEntry[]
  preferences     UserPreferences?
  activeSessions  ActiveSession[]
  projectMemberships ProjectMember[]

  @@index([email])
}

// ─── Auth (NextAuth adapter models) ───────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Membership (User ↔ Organisation join, carries Role) ─────────────────────

model Membership {
  id             String   @id @default(cuid())
  tenantId       String   // = organizationId — explicit for query clarity
  userId         String
  organizationId String
  role           Role     @default(VIEWER)
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([tenantId])
  @@index([userId])
  @@index([organizationId])
}

// ─── Invitations ──────────────────────────────────────────────────────────────

model Invitation {
  id             String           @id @default(cuid())
  tenantId       String
  organizationId String
  email          String
  role           Role             @default(VIEWER)
  token          String           @unique @default(cuid())
  status         InvitationStatus @default(PENDING)
  invitedById    String
  expiresAt      DateTime
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([tenantId])
  @@index([token])
  @@index([email])
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id             String        @id @default(cuid())
  tenantId       String
  organizationId String
  name           String
  description    String?       @db.Text
  status         ProjectStatus @default(ACTIVE)
  priority       Priority      @default(MEDIUM)
  startDate      DateTime?
  dueDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks        Task[]
  files        File[]
  members      ProjectMember[]

  @@index([tenantId])
  @@index([organizationId])
  @@index([status])
}

// ─── Project Members (assignment of users to a project) ──────────────────────

model ProjectMember {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String
  userId    String
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([tenantId])
  @@index([projectId])
  @@index([userId])
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  tenantId    String
  projectId   String
  title       String
  description String?    @db.Text
  status      TaskStatus @default(BACKLOG)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  position    Int        @default(0) // for Kanban ordering
  assigneeId  String?
  creatorId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee       User?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator        User            @relation("TaskCreator", fields: [creatorId], references: [id])
  comments       Comment[]
  files          File[]
  subtasks       SubTask[]
  checklistItems ChecklistItem[]
  timeEntries    TimeEntry[]
  labels         TaskLabel[]

  @@index([tenantId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

// ─── Task Labels ──────────────────────────────────────────────────────────────

model TaskLabel {
  id     String @id @default(cuid())
  taskId String
  name   String
  color  String @default("#6366f1")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ─── Comments ─────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  tenantId  String
  taskId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([tenantId])
  @@index([taskId])
}

// ─── Files ────────────────────────────────────────────────────────────────────

model File {
  id             String   @id @default(cuid())
  tenantId       String
  organizationId String
  uploadedById   String
  projectId      String?
  taskId         String?
  name           String
  key            String   // S3 object key
  url            String
  size           Int      // bytes
  mimeType       String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([taskId])
  @@index([projectId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id             String           @id @default(cuid())
  tenantId       String
  organizationId String
  userId         String
  type           NotificationType
  title          String
  body           String
  read           Boolean          @default(false)
  entityId       String?          // e.g. taskId or projectId
  entityType     String?          // "task" | "project"
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, read])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id             String      @id @default(cuid())
  tenantId       String
  organizationId String
  userId         String
  action         AuditAction
  entityType     String      // "task" | "project" | "user" | ...
  entityId       String
  metadata       Json?       // before/after state, extra context
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
}

// ─── Subscription (Stripe) ────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

// ─── Task Productivity Extras (Subtasks, Checklist, Time Tracking) ───────────

model SubTask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  completed Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  checked   Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TimeEntry {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  minutes   Int
  note      String?  @db.Text
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

// ─── User Preferences & Sessions ──────────────────────────────────────────────

model UserPreferences {
  id                 String   @id @default(cuid())
  userId             String   @unique
  theme              String   @default("system") // "light" | "dark" | "system"
  emailNotifications Boolean  @default(true)
  taskAssignedNotif  Boolean  @default(true)
  taskUpdatedNotif   Boolean  @default(true)
  defaultView        String   @default("kanban") // "kanban" | "list" | "calendar"
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActiveSession {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String   @unique
  deviceLabel String   @default("Unknown device")
  ipAddress   String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  revoked     Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
}
model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())

  @@index([stripeEventId])
}
